---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
}
const {
  title = "ContainerUI — a native Mac app for Apple's container tool",
  description = "ContainerUI is a native SwiftUI app for Apple's container command-line tool. Run and inspect Linux containers, browse images, and control the background service — all from one window.",
} = Astro.props
// One source of truth for absolute URLs: `site` in astro.config.mjs.
const site = (Astro.site?.href ?? "https://container-ui.fly.dev/").replace(/\/$/, "")
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site} />

    <link rel="icon" type="image/png" sizes="128x128" href="/app-icon-128.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/app-icon-256.png" />
    <meta name="theme-color" content="#080912" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#eef1fb" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ContainerUI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site} />
    <meta property="og:image" content={`${site}/og/index.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ContainerUI — a native Mac app for Apple's container tool" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og/index.png`} />

    <script is:inline>
      // Mark JS available so scroll-reveal can hide-then-reveal. Without this
      // flag the page renders fully (no blank-page-on-JS-failure).
      document.documentElement.classList.add("js")
      // ContainerUI is a macOS-only app, so the Download CTA is meaningless on a
      // phone/tablet. Flag mobile agents before paint (no flicker) so CSS can
      // hide it. UA Client Hints where available, UA-string sniff as fallback.
      try {
        var isMobile =
          (navigator.userAgentData && navigator.userAgentData.mobile) ||
          /Android|iPhone|iPod|iPad|IEMobile|Opera Mini|Mobile|Windows Phone/i.test(navigator.userAgent)
        if (isMobile) document.documentElement.classList.add("is-mobile")
      } catch (_) {}
      // No-flash appearance: explicit choice wins, else follow the OS. Dark is home.
      try {
        const saved = localStorage.getItem("theme")
        const theme =
          saved || (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark")
        document.documentElement.setAttribute("data-theme", theme)
      } catch (_) {}
    </script>
    <noscript>
      <style>
        [data-reveal] { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <div class="aurora" aria-hidden="true"></div>
    <slot />
    <script>
      import "@/scripts/site.ts"
    </script>
  </body>
</html>
