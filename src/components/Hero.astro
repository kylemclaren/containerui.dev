---
import Icon from "./Icon.astro"
import AppWindow from "./AppWindow.astro"
import { getRelease } from "@/lib/release"
const { dmgUrl, version } = await getRelease()
---
<section class="hero" id="top">
  <div class="wrap">
    <div class="hero-copy">
      <span class="eyebrow" data-reveal><span class="dot"></span>macOS 26 · Apple silicon</span>
      <h1 class="display wordmark" data-reveal style="--reveal-delay:60ms">
        Container<span class="grad-text">UI</span>
      </h1>
      <p class="lede" data-reveal style="--reveal-delay:120ms">
        A native Mac app for Apple's <code>container</code> tool. Run Linux containers, search Docker Hub,
        browse images, manage volumes and networks, and control the background service — all from one window.
      </p>
      <div class="hero-cta" data-reveal style="--reveal-delay:180ms">
        <a class="pill pill-accent hero-dl" href={dmgUrl} data-dl-href>
          <Icon name="download" size={18} /> Download for macOS
        </a>
        <button
          class="pill pill-ghost hero-brew"
          type="button"
          data-copy="brew install --cask kylemclaren/tap/container-ui"
          aria-label="Copy the Homebrew install command"
        >
          <code class="hero-brew-cmd hero-brew-full"><span class="hero-brew-p">$</span>brew install --cask kylemclaren/tap/container-ui</code>
          <code class="hero-brew-cmd hero-brew-min"><span class="hero-brew-p">$</span>brew install --cask container-ui</code>
          <Icon name="copy" size={17} class="i-copy" />
          <Icon name="check" size={17} class="i-check" />
        </button>
      </div>
      <p class="hero-meta" data-reveal style="--reveal-delay:240ms">
        <code data-dl-version>{version}</code> · Requires macOS 26 on Apple silicon<span class="msep">·</span><a class="hero-link" href="#install">build from source</a>
      </p>
    </div>

    <div class="hero-stage" id="hero-stage" data-reveal style="--reveal-delay:280ms">
      <div class="hero-glow" aria-hidden="true"></div>
      <AppWindow />
      <p class="mock-caption">Live demo · filter, hover a row to reveal its command</p>
    </div>
  </div>
</section>
