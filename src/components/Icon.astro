---
// Inline SVG icons — line-weight tuned to feel like SF Symbols.
interface Props {
  name: string
  size?: number
  class?: string
  "stroke-width"?: number
}
const { name, size = 20, class: klass = "", "stroke-width": sw = 1.7 } = Astro.props

// Solid icons render their own fills; line icons inherit currentColor via stroke.
const line: Record<string, string> = {
