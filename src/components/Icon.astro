  apple: `<path fill="currentColor" d="M16.36 12.68c.02 2.5 2.19 3.33 2.21 3.34-.02.06-.35 1.2-1.15 2.37-.69 1.02-1.41 2.03-2.55 2.05-1.11.02-1.47-.66-2.75-.66-1.27 0-1.67.64-2.72.68-1.09.04-1.93-1.1-2.63-2.11-1.42-2.07-2.51-5.85-1.05-8.41.72-1.27 2.02-2.08 3.42-2.1 1.07-.02 2.09.72 2.75.72.66 0 1.9-.9 3.2-.76.54.02 2.07.22 3.05 1.65-.08.05-1.82 1.07-1.8 3.24M14.3 4.9c.58-.71.98-1.7.87-2.68-.84.03-1.86.56-2.47 1.26-.54.63-1.02 1.63-.89 2.6.94.07 1.9-.48 2.49-1.18"/>`,
}

const isSolid = name in solid
const inner = isSolid ? solid[name] : (line[name] ?? "")
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isSolid ? "currentColor" : "none"}
  stroke={isSolid ? "none" : "currentColor"}
  stroke-width={sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={klass}
  aria-hidden="true"
  set:html={inner}
/>
